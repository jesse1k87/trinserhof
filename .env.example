# Firebase database URL — the only Firebase config value that differs
# between production and staging (everything else is hardcoded in
# packages/constants/src/FIREBASE_CONFIG.ts since it isn't secret).
# Used by apps/client and apps/form at build time (injected by esbuild define)
# Used by apps/server at runtime (read from process.env via dotenv)
#
# For local development: copy this file to .env at the repo root and fill in the value.
# For Netlify: set this as an environment variable in the Netlify UI.

FIREBASE_DATABASE_URL=

# Server-only (apps/server)
PORT=4000
CLIENT_URL=http://127.0.0.1:8080
STRIPE_PRIVATE_KEY=
