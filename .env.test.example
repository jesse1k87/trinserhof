# Test environment credentials — points at a SECOND Realtime Database
# instance within the SAME Firebase project as .env.example.
#
# Setup:
# 1. In the Firebase console, go to Realtime Database > Create database,
#    and create a second instance (e.g. named "<project-id>-test").
# 2. Copy this file to .env.test at the repo root.
# 3. Copy every value from your .env EXCEPT FIREBASE_DATABASE_URL — set
#    that to the new test instance's URL instead.
# 4. Run `npm run dev:test` or `npm run build:test` to use it.
#
# For deployed test environments (Netlify branch deploy, Vercel preview),
# set FIREBASE_DATABASE_URL directly to the test instance URL in that
# platform's environment variable UI instead of using this file.

FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Server-only (apps/server)
PORT=4000
CLIENT_URL=http://127.0.0.1:8080
STRIPE_PRIVATE_KEY=
