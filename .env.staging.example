# Staging credentials — points at a SECOND Realtime Database instance
# within the SAME Firebase project as .env.example.
#
# This is the DEFAULT database for local development. `npm run dev` and
# `npm run build` load .env.staging unless APP_ENV=production is set, so
# you connect to staging data automatically on your laptop and can't
# accidentally write to production.
#
# Setup:
# 1. In the Firebase console, go to Realtime Database > Create database,
#    and create a second instance (e.g. named "<project-id>-staging").
# 2. Copy this file to .env.staging at the repo root.
# 3. Copy every value from your .env EXCEPT FIREBASE_DATABASE_URL — set
#    that to the new staging instance's URL instead.
# 4. Run `npm run dev` or `npm run build` as usual — staging is the default.
#    To explicitly use production locally, run `npm run dev:prod` or
#    `npm run build:prod` instead.
#
# For deployed staging environments (Netlify branch deploy, Vercel preview),
# set FIREBASE_DATABASE_URL directly to the staging instance URL in that
# platform's environment variable UI instead of using this file.

FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Server-only (apps/server)
PORT=4000
CLIENT_URL=http://127.0.0.1:8080
STRIPE_PRIVATE_KEY=
