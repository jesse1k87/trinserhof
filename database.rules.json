{
  "rules": {
    ".read": "auth.token.email != null && (';jesse1k87@gmail.com;jennifer.m.covi@gmail.com;jessica.covi@gmail.com;harry.covi@gmail.com').contains(';' + auth.token.email + ';')",
    ".write": "auth.token.email === 'jesse1k87@gmail.com'",
    "bookings": {
      "$bookingId": {
        ".validate": "newData.hasChildren(['checkIn', 'checkOut', 'status', 'roomId', 'channel', 'adults', 'children', 'babies', 'pets', 'price', 'priceFixed', 'halbpension'])",
        "email": { ".validate": "newData.isString()" },
        "checkIn": { ".validate": "newData.isString()" },
        "checkOut": { ".validate": "newData.isString()" },
        "status": { ".validate": "newData.isString()" },
        "roomId": { ".validate": "newData.isString()" },
        "channel": { ".validate": "newData.isString()" },
        "adults": { ".validate": "newData.isNumber()" },
        "children": { ".validate": "newData.isNumber()" },
        "babies": { ".validate": "newData.isNumber()" },
        "pets": { ".validate": "newData.isNumber()" },
        "price": { ".validate": "newData.isNumber()" },
        "priceFixed": { ".validate": "newData.isString()" },
        "halbpension": { ".validate": "newData.isBoolean()" }
      }
    },
    "customers": {
      "$customerId": {
        ".validate": "newData.hasChildren(['id', 'name', 'email'])",
        "id": { ".validate": "newData.isString()" },
        "name": { ".validate": "newData.isString()" },
        "email": { ".validate": "newData.isString()" },
        "phone": { ".validate": "newData.isString()" },
        "dateOfBirth": { ".validate": "newData.isString()" },
        "deleted": { ".validate": "newData.isBoolean()" }
      }
    },
    "rooms": {
      "$roomId": {
        ".validate": "newData.hasChildren(['id', 'type', 'label', 'description', 'pricePerNight'])",
        "id": { ".validate": "newData.isString()" },
        "type": { ".validate": "newData.isString()" },
        "label": { ".validate": "newData.isString()" },
        "description": { ".validate": "newData.isString()" },
        "pricePerNight": {
          ".validate": "newData.isNumber() || newData.hasChildren()"
        }
      }
    },
    "users": {
      "$userId": {
        ".write": "auth.token.email === 'jesse1k87@gmail.com' || (data.exists() && data.child('email').val() === auth.token.email)",
        ".validate": "newData.hasChildren(['id', 'email', 'role'])",
        "id": {
          ".validate": "newData.isString() && (auth.token.email === 'jesse1k87@gmail.com' || newData.val() === data.val())"
        },
        "email": {
          ".validate": "newData.isString() && (auth.token.email === 'jesse1k87@gmail.com' || newData.val() === data.val())"
        },
        "role": {
          ".validate": "newData.isString() && (newData.val() === 'BLOCKED' || newData.val() === 'VIEWER' || newData.val() === 'MANAGER' || newData.val() === 'OWNER') && (auth.token.email === 'jesse1k87@gmail.com' || newData.val() === data.val())"
        },
        "image": { ".validate": "newData.isString()" }
      }
    },
    "auditLog": {
      "$entryId": {
        ".write": "!data.exists() && auth.token.email != null && (';jesse1k87@gmail.com;jennifer.m.covi@gmail.com;jessica.covi@gmail.com;harry.covi@gmail.com').contains(';' + auth.token.email + ';')",
        ".validate": "newData.hasChildren(['email', 'event', 'timestamp'])",
        "email": {
          ".validate": "newData.isString() && newData.val() === auth.token.email"
        },
        "event": {
          ".validate": "newData.isString() && (newData.val() === 'LOGIN' || newData.val() === 'LOGOUT' || newData.val() === 'BOOKING_CREATED' || newData.val() === 'BOOKING_UPDATED' || newData.val() === 'BOOKING_DELETED' || newData.val() === 'BOOKING_RESTORED' || newData.val() === 'CUSTOMER_CREATED' || newData.val() === 'CUSTOMER_UPDATED' || newData.val() === 'CUSTOMER_DELETED' || newData.val() === 'CUSTOMER_RESTORED' || newData.val() === 'ROOM_UPDATED')"
        },
        "timestamp": { ".validate": "newData.isNumber()" }
      }
    }
  }
}
