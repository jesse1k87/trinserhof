{
  "name": "trinserhof",
  "version": "1.0.0",
  "homepage": "https://github.com/jesse1k87/trinserhof#readme",
  "bugs": {
    "url": "https://github.com/jesse1k87/trinserhof/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jesse1k87/trinserhof.git"
  },
  "workspaces": [
    "apps/pms",
    "packages/constants",
    "packages/firebase",
    "packages/helpers",
    "packages/prettier",
    "packages/supabase",
    "packages/theme",
    "packages/tsconfig",
    "packages/types",
    "packages/ui"
  ],
  "scripts": {
    "build": "turbo run tsc build",
    "depcheck": "node depcheck.mjs",
    "dev": "turbo run dev",
    "download-db": "tsx scripts/download-firebase-data.mjs",
    "format": "prettier --write ./scripts/*.ts && turbo run format",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "mews-import": "npm -w @trinserhof/supabase run mews-import",
    "pms": "npm -w pms run dev",
    "precommit": "turbo run sort-package-json && npm install && turbo run format",
    "sort-package-json": "sort-package-json && turbo run sort-package-json",
    "test": "turbo run test",
    "tsc": "turbo run tsc"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "depcheck": "^1.4.7",
    "dotenv": "^16.4.5",
    "lucide-react": "^0.575.0",
    "react-day-picker": "^8.10.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.2",
    "esbuild-plugin-tailwindcss": "^2.2.0",
    "firebase": "^10.12.4",
    "oxlint": "1.71.0",
    "sort-package-json": "^2.10.0",
    "tsx": "^4.22.4",
    "turbo": "^2.0.6",
    "vitest": "^2.0.5"
  },
  "packageManager": "npm@10.7.0"
}
