{
  "name": "bookings",
  "version": "1.0.0",
  "homepage": "https://github.com/jesse-mtm/bookings#readme",
  "bugs": {
    "url": "https://github.com/jesse-mtm/bookings/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jesse-mtm/bookings.git"
  },
  "workspaces": [
    "apps/admin",
    "apps/client",
    "apps/server",
    "packages/components",
    "packages/constants",
    "packages/database",
    "packages/helpers",
    "packages/prettier",
    "packages/tsconfig",
    "packages/types"
  ],
  "scripts": {
    "start": "npm -w server run build && node apps/server/dist/index.js",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "precommit": "turbo run sort-package-json && npm install && turbo run format",
    "sort-package-json": "sort-package-json && turbo run sort-package-json",
    "tsc": "turbo run tsc"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "sort-package-json": "^2.10.0",
    "turbo": "^2.0.6"
  },
  "packageManager": "npm@10.7.0"
}
