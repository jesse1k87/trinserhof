  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jesse1k87/trinserhof.git"
  },
  "workspaces": [
    "apps/pms",
    "packages/constants",
    "packages/firebase",
    "packages/helpers",
    "packages/prettier",
    "packages/supabase",
    "packages/theme",
    "packages/tsconfig",
    "packages/types",
    "packages/ui"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "download-db": "tsx scripts/download-firebase-data.mjs",
    "format": "sort-package-json && turbo sort-package-json && turbo format",
    "import-mews": "npm -w @trinserhof/supabase run import-mews",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "pms": "npm -w pms run dev",
    "test": "turbo test",
    "tsc": "turbo tsc"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "lucide-react": "^0.575.0",
    "react-day-picker": "^8.10.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.2",
    "esbuild-plugin-tailwindcss": "^2.2.0",
    "firebase": "^10.12.4",
    "oxlint": "1.71.0",
    "sort-package-json": "^2.10.0",
    "tsx": "^4.22.4",
    "turbo": "^2.0.6",
    "vitest": "^2.0.5"
  },
  "packageManager": "npm@10.7.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}