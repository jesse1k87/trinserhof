generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  MANAGER
  READER
  BLOCKED
}

model User {
  id    String   @id @default(uuid())
  email String   @unique
  role  UserRole @default(BLOCKED)
  image String?
  theme String?
}
