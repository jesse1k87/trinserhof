{
  "name": "@trinserhof/supabase",
  "version": "1.0.0",
  "description": "Database for @trinserhof/pms",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "npm run db:migrate && npm run db:generate && npm run db:seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset && npm run build",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "format": "prettier . --write",
    "lint": "oxlint --config ../../.oxlintrc.json",
    "mews-import": "NODE_OPTIONS=\"--experimental-websocket\" tsx scripts/mews-import.ts",
    "sort-package-json": "sort-package-json"
  },
  "prettier": "@trinserhof/prettier",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.45.4",
    "@trinserhof/constants": "*",
    "@trinserhof/helpers": "*",
    "@trinserhof/types": "*",
    "firebase": "^10.12.4"
  },
  "devDependencies": {
    "@trinserhof/prettier": "*",
    "@trinserhof/tsconfig": "*",
    "prisma": "^6.19.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
