generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Theme {
  light
  dark
}

// Roles are no longer a fixed enum — they live here as editable rows, each
// granting an explicit set of permissions (see the Role model in
// @trinserhof/types for the permission keys). A user's `role` references a
// Role by its `id` (e.g. "OWNER"). Seed fixtures live in prisma/fixtures/ROLES.ts.
model Role {
  id          String   @id
  name        String
  permissions String[]
}

model User {
  id     String  @id @default(uuid())
  email  String  @unique
  role   String  @default("BLOCKED")
  image  String?
  theme  Theme?
  // BCP-47 locale tag (e.g. "de-AT", "en-US") used to format dates/currency
  // throughout the PMS. Falls back to "de-AT" when unset (see DEFAULT_LOCALE
  // in @trinserhof/types).
  locale String?
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum BookingOrigin {
  AIRBNB
  BOOKING_COM
  EMAIL
  IN_PERSON
  JESSE
  PHONE
  UNKNOWN
  WEBSITE_FORM
  WEBSITE_FORM_MEWS
}

model Booking {
  id            String        @id @default(uuid())
  created       DateTime      @default(now())
  origin        BookingOrigin @default(UNKNOWN)
  status        BookingStatus @default(PENDING)
  checkIn       DateTime      @db.Date
  checkOut      DateTime      @db.Date
  cancelled     DateTime?
  confirmed     DateTime?
  checkedIn     DateTime?
  checkedOut    DateTime?
  roomId        String
  customers     String[]
  adults        Int
  children      Int
  pets          Int
  pricePerNight Float?
  note          String
}

enum AuditEvent {
  LOGIN
  LOGOUT
  BOOKING_CREATED
  BOOKING_UPDATED
  BOOKING_RESTORED
  CUSTOMER_CREATED
  CUSTOMER_UPDATED
  CUSTOMERS_MERGED
  INVOICE_CREATED
  INVOICE_UPDATED
  ROLE_CREATED
  ROLE_UPDATED
  ROOM_CREATED
  ROOM_UPDATED
  ROOM_TYPE_CREATED
  ROOM_TYPE_UPDATED
  PRICE_BASE_UPDATED
  PRICE_OVERRIDE_SET
  PRICE_OVERRIDE_REMOVED
  TABLE_CREATED
  TABLE_UPDATED
  TABLE_RESERVATION_CREATED
  TABLE_RESERVATION_UPDATED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_RESTORED
  ACCOUNTING_CATEGORY_CREATED
  ACCOUNTING_CATEGORY_UPDATED
  ACCOUNTING_CATEGORY_RESTORED
  MIGRATE_LEGACY_BOOKINGS
  BOOKINGS_WIPED
  BOOKINGS_IMPORTED
  CUSTOMERS_WIPED
  ROOMS_WIPED
  PROPERTY_CREATED
  PROPERTY_UPDATED
}

model AuditLogEntry {
  id        String     @id @default(uuid())
  email     String
  event     AuditEvent
  timestamp BigInt
}

model Customer {
  id           String    @id @default(uuid())
  created      DateTime  @db.Date
  name         String
  surname      String?
  email        String?
  phone        String?
  dateOfBirth  DateTime? @db.Date
  nationality  String?
  language     String?
  street       String?
  streetNumber String?
  postcode     String?
  city         String?
  country      String?
}

model Invoice {
  id         String   @id @default(uuid())
  number     String   @unique
  created    DateTime @db.Date
  customerId String
  bookingIds String[]
  products   Json
  notes      String?
}

model Product {
  id                   String  @id @default(uuid())
  name                 String
  price                Float
  accountingCategoryId String
  variants             Json?
}

model AccountingCategory {
  id         String @id @default(uuid())
  name       String
  taxRate    Int
  ledgerCode Int
  color      String
}

model RestaurantTable {
  id        String @id @default(uuid())
  number    Int
  areaName  String
  maxGuests Int
}

model RestaurantReservation {
  id             String   @id @default(uuid())
  start          DateTime
  numberOfPeople Int
  tableId        String?
  customerId     String?
}

model RoomType {
  id          String              @id
  label       String
  description String?
  basePrice   Float
  occupancies RoomTypeOccupancy[]
}

// A property is a hotel. For now there is a single property (Hotel Trinserhof),
// seeded in prisma/seed.ts, but the schema is multi-property ready: every Room
// belongs to exactly one Property (mandatory relation).
model Property {
  id                       String @id @default(uuid())
  name                     String
  legalName                String
  website                  String
  email                    String
  phone                    String
  checkInTime              String
  checkOutTime             String
  address                  String
  cityTaxPerPersonPerNight Float
  taxRegistryNumber        String
  iban                     String
  bic                      String
  rooms                    Room[]
}

model Room {
  id           String     @id @default(uuid())
  type         String
  propertyId   String
  property     Property   @relation(fields: [propertyId], references: [id])
  maxCustomers Int
  floor        Int
  color        String
  balcony      Boolean?
  tv           Boolean?
  shower       Boolean?
  bathtub      Boolean?
  toilet       Boolean?
  phone        Boolean?
  desk         Boolean?
  mountainView Boolean?
  kingBed      Int?
  queenBed     Int?
  singleBed    Int?
  sleepSofa    Int?
  spaces       Int?
}

model Price {
  id         String    @id @default(uuid())
  roomTypeId String
  date       DateTime? @db.Date
  amount     Float

  @@unique([roomTypeId, date])
}

model RoomTypeOccupancy {
  id         String   @id @default(uuid())
  date       DateTime @db.Date
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  occupancy  Decimal  @db.Decimal(5, 2)

  @@unique([roomTypeId, date])
}
