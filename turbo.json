{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "APP_ENV",
        "FIREBASE_API_KEY",
        "FIREBASE_APP_ID",
        "FIREBASE_AUTH_DOMAIN",
        "FIREBASE_DATABASE_URL",
        "FIREBASE_DB_NAMESPACE",
        "FIREBASE_MESSAGING_SENDER_ID",
        "FIREBASE_PROJECT_ID",
        "FIREBASE_STORAGE_BUCKET"
      ],
      "outputs": [
        "public/**",
        "dist/**"
      ]
    },
    "dev": {
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "sort-package-json": {
      "cache": false,
      "outputs": []
    },
    "test": {
      "cache": false,
      "outputs": []
    },
    "tsc": {
      "cache": false,
      "outputs": []
    }
  }
}