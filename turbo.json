{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "public/**",
        "dist/**"
      ]
    },
    "@trinserhof/supabase-db#build": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "sort-package-json": {
      "cache": false,
      "outputs": []
    },
    "test": {
      "cache": false,
      "outputs": []
    },
    "tsc": {
      "dependsOn": [
        "^tsc"
      ],
      "outputs": [
        "**/*.tsbuildinfo"
      ]
    }
  }
}