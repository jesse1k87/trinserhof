{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["public/**", "dist/**"]
    },
    "@trinserhof/supabase#build": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "sort-package-json": {
      "cache": false,
      "outputs": []
    },
    "test": {
      "cache": false,
      "outputs": []
    },
    "tsc": {
      "dependsOn": ["^tsc", "@trinserhof/supabase#build"],
      "outputs": ["**/*.tsbuildinfo"]
    }
  }
}
