{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "APP_ENV",
        "FIREBASE_DATABASE_URL"
      ],
      "outputs": [
        "public/**",
        "dist/**"
      ]
    },
    "dev": {
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "sort-package-json": {
      "cache": false,
      "outputs": []
    },
    "test": {
      "cache": false,
      "outputs": []
    },
    "tsc": {
      "cache": false,
      "outputs": []
    }
  }
}