{
  "name": "client",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "scripts": {
    "build": "node ./build.mjs",
    "build:js": "esbuild src/index.js --bundle --outfile=public/index.js --loader:.js=tsx --format=cjs",
    "dev": "concurrently \"npm run watch\" \"npm run serve\"",
    "format": "prettier . --write",
    "serve": "http-server",
    "sort-package-json": "sort-package-json",
    "tsc": "tsc",
    "watch": "node ./build.mjs watch"
  },
  "browserslist": [
    "defaults"
  ],
  "prettier": "@bookings/prettier",
  "dependencies": {
    "@bookings/constants": "*",
    "@bookings/database": "*",
    "@bookings/helpers": "*",
    "@bookings/types": "*",
    "@bookings/ui": "*",
    "date-fns": "^3.6.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "vis-data": "^7.1.9",
    "vis-timeline": "^7.7.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@bookings/prettier": "*",
    "@bookings/tsconfig": "*",
    "http-server": "^14.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.23.0",
    "esbuild-plugin-tailwindcss": "^1.2.0",
    "sort-package-json": "^2.10.0"
  }
}
