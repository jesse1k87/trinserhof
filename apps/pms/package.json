{
  "name": "pms",
  "version": "1.0.0",
  "description": "Property Management System (PMS) for Hotel Trinserhof",
  "main": "./dist/index.js",
  "scripts": {
    "build": "node ./build.mjs",
    "build:js": "esbuild src/index.js --bundle --outfile=public/index.js --loader:.js=tsx --format=cjs",
    "dev": "concurrently \"npm run watch\" \"npm run serve\"",
    "format": "prettier . --write",
    "lint": "oxlint --config ../../.oxlintrc.json",
    "serve": "http-server public --proxy http://localhost:8080?",
    "sort-package-json": "sort-package-json",
    "tsc": "tsc",
    "watch": "node ./build.mjs watch"
  },
  "browserslist": [
    "defaults"
  ],
  "prettier": "@trinserhof/prettier",
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@trinserhof/constants": "*",
    "@trinserhof/firebase": "*",
    "@trinserhof/helpers": "*",
    "@trinserhof/supabase": "*",
    "@trinserhof/theme": "*",
    "@trinserhof/types": "*",
    "@trinserhof/ui": "*",
    "@vercel/analytics": "^2.0.1",
    "date-fns": "^3.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.1",
    "vis-data": "^8.0.4",
    "vis-timeline": "^8.5.1"
  },
  "devDependencies": {
    "@trinserhof/prettier": "*",
    "@trinserhof/tsconfig": "*",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.1",
    "http-server": "^14.1.1"
  }
}
