# Firebase database URL (same project as apps/server; other config values
# are hardcoded in packages/constants/src/FIREBASE_CONFIG.ts since they
# aren't secret)
FIREBASE_DATABASE_URL=

# Mews Connector API (sandbox demo credentials, see https://www.mews.com)
MEWS_CLIENT_TOKEN=
MEWS_ACCESS_TOKEN=
MEWS_SERVICE_ID=
# Optional, defaults to the demo sandbox (https://api.mews-demo.com). Set to
# https://api.mews.com for production once credentials/service id are real.
MEWS_BASE_URL=
