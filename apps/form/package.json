{
  "name": "form",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "scripts": {
    "build": "node ./build.mjs",
    "build:js": "esbuild src/index.js --bundle --outfile=public/index.js --loader:.js=tsx --format=cjs",
    "dev": "concurrently \"npm run watch\" \"npm run serve\"",
    "format": "prettier . --write",
    "serve": "http-server",
    "sort-package-json": "sort-package-json",
    "test": "vitest run",
    "tsc": "tsc",
    "watch": "node ./build.mjs watch"
  },
  "browserslist": [
    "defaults"
  ],
  "prettier": "@trinserhof/prettier",
  "dependencies": {
    "@trinserhof/database": "*",
    "@trinserhof/helpers": "*",
    "@trinserhof/ui": "*",
    "react-day-picker": "^8.10.1"
  },
  "devDependencies": {
    "@trinserhof/prettier": "*",
    "@trinserhof/tsconfig": "*",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "esbuild-plugin-tailwindcss": "^2.2.0",
    "sort-package-json": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "vitest": "^2.0.5"
  }
}
