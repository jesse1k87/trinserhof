{
  "name": "form",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "scripts": {
    "build": "node ./build.mjs",
    "build:js": "esbuild src/index.js --bundle --outfile=public/index.js --loader:.js=tsx --format=cjs",
    "dev": "concurrently \"npm run watch\" \"npm run serve\"",
    "format": "prettier . --write",
    "serve": "http-server",
    "sort-package-json": "sort-package-json",
    "test": "vitest run --passWithNoTests",
    "tsc": "tsc",
    "watch": "node ./build.mjs watch"
  },
  "browserslist": [
    "defaults"
  ],
  "prettier": "@trinserhof/prettier",
  "dependencies": {
    "@trinserhof/database": "*",
    "@trinserhof/helpers": "*",
    "@trinserhof/ui": "*"
  },
  "devDependencies": {
    "@trinserhof/prettier": "*",
    "@trinserhof/tsconfig": "*",
    "daisyui": "^5.5.23",
    "esbuild": "^0.28.1"
  }
}
