{
  "name": "form",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "scripts": {
    "build": "node ./build.mjs",
    "build:js": "esbuild src/index.js --bundle --outfile=public/index.js --loader:.js=tsx --format=cjs",
    "dev": "concurrently \"npm run watch\" \"npm run serve\"",
    "format": "prettier . --write",
    "serve": "http-server",
    "sort-package-json": "sort-package-json",
    "test": "vitest run",
    "tsc": "tsc",
    "watch": "node ./build.mjs watch"
  },
  "browserslist": [
    "defaults"
  ],
  "prettier": "@bookings/prettier",
  "dependencies": {
    "@bookings/database": "*",
    "@bookings/helpers": "*",
    "@bookings/ui": "*",
    "react-day-picker": "^8.10.1"
  },
  "devDependencies": {
    "@bookings/prettier": "*",
    "@bookings/tsconfig": "*",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "esbuild": "^0.23.0",
    "esbuild-plugin-tailwindcss": "^1.2.0",
    "sort-package-json": "^2.10.0",
    "vitest": "^2.0.5"
  }
}
